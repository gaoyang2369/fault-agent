{
  "$defs": {
    "AggregationFunction": {
      "enum": [
        "MIN",
        "MAX",
        "AVG"
      ],
      "title": "AggregationFunction",
      "type": "string"
    },
    "AggregationSpec": {
      "additionalProperties": false,
      "properties": {
        "window_seconds": {
          "exclusiveMinimum": 0,
          "title": "Window Seconds",
          "type": "integer"
        },
        "functions": {
          "items": {
            "$ref": "#/$defs/AggregationFunction"
          },
          "minItems": 1,
          "title": "Functions",
          "type": "array"
        }
      },
      "required": [
        "window_seconds",
        "functions"
      ],
      "title": "AggregationSpec",
      "type": "object"
    },
    "TimeRange": {
      "additionalProperties": false,
      "properties": {
        "start": {
          "format": "date-time",
          "title": "Start",
          "type": "string"
        },
        "end": {
          "format": "date-time",
          "title": "End",
          "type": "string"
        }
      },
      "required": [
        "start",
        "end"
      ],
      "title": "TimeRange",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "asset_id": {
      "anyOf": [
        {
          "maxLength": 128,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Asset Id"
    },
    "asset_code": {
      "anyOf": [
        {
          "maxLength": 128,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Asset Code"
    },
    "time_range": {
      "$ref": "#/$defs/TimeRange"
    },
    "signal_codes": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Signal Codes",
      "type": "array"
    },
    "aggregation": {
      "anyOf": [
        {
          "$ref": "#/$defs/AggregationSpec"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "max_points": {
      "default": 10000,
      "exclusiveMinimum": 0,
      "title": "Max Points",
      "type": "integer"
    }
  },
  "required": [
    "time_range",
    "signal_codes"
  ],
  "title": "TelemetryQueryCommand",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
