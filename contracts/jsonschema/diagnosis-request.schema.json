{
  "$defs": {
    "TimeRange": {
      "additionalProperties": false,
      "description": "表示左闭右开语义的有效时间范围，并统一归一化为 UTC。",
      "properties": {
        "start": {
          "format": "date-time",
          "title": "Start",
          "type": "string"
        },
        "end": {
          "format": "date-time",
          "title": "End",
          "type": "string"
        }
      },
      "required": [
        "start",
        "end"
      ],
      "title": "TimeRange",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "创建诊断运行的公开请求，不接受调用者身份或源数据定位信息。",
  "properties": {
    "asset_id": {
      "anyOf": [
        {
          "maxLength": 128,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Asset Id"
    },
    "asset_code": {
      "anyOf": [
        {
          "maxLength": 128,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Asset Code"
    },
    "time_range": {
      "$ref": "#/$defs/TimeRange"
    },
    "diagnosis_profile": {
      "minLength": 1,
      "title": "Diagnosis Profile",
      "type": "string"
    },
    "include_report": {
      "default": false,
      "title": "Include Report",
      "type": "boolean"
    }
  },
  "required": [
    "time_range",
    "diagnosis_profile"
  ],
  "title": "DiagnosisRequest",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:fault-agent:contract:1.0.0:diagnosis-request",
  "x-contract-version": "1.0.0"
}
