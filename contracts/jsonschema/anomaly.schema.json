{
  "$defs": {
    "AnomalySeverity": {
      "description": "确定性异常的严重程度枚举。",
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ],
      "title": "AnomalySeverity",
      "type": "string"
    },
    "TimeRange": {
      "additionalProperties": false,
      "description": "表示左闭右开语义的有效时间范围，并统一归一化为 UTC。",
      "properties": {
        "start": {
          "format": "date-time",
          "title": "Start",
          "type": "string"
        },
        "end": {
          "format": "date-time",
          "title": "End",
          "type": "string"
        }
      },
      "required": [
        "start",
        "end"
      ],
      "title": "TimeRange",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "描述由指定版本规则识别、且有证据支撑的运行异常。",
  "properties": {
    "anomaly_id": {
      "minLength": 1,
      "title": "Anomaly Id",
      "type": "string"
    },
    "anomaly_type": {
      "minLength": 1,
      "title": "Anomaly Type",
      "type": "string"
    },
    "severity": {
      "$ref": "#/$defs/AnomalySeverity"
    },
    "time_range": {
      "$ref": "#/$defs/TimeRange"
    },
    "rule_id": {
      "minLength": 1,
      "title": "Rule Id",
      "type": "string"
    },
    "evidence_ids": {
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "title": "Evidence Ids",
      "type": "array"
    }
  },
  "required": [
    "anomaly_id",
    "anomaly_type",
    "severity",
    "time_range",
    "rule_id",
    "evidence_ids"
  ],
  "title": "Anomaly",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:fault-agent:contract:1.0.0:anomaly",
  "x-contract-version": "1.0.0"
}
