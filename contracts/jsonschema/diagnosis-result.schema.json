{
  "$defs": {
    "AllowedAnalysis": {
      "description": "在当前数据质量下允许执行的分析类别。",
      "enum": [
        "POINT_SUMMARY",
        "REPORTED_EVENT_DETECTION",
        "TREND_ANALYSIS",
        "DURATION_RULES"
      ],
      "title": "AllowedAnalysis",
      "type": "string"
    },
    "Anomaly": {
      "additionalProperties": false,
      "description": "描述由指定版本规则识别、且有证据支撑的运行异常。",
      "properties": {
        "anomaly_id": {
          "minLength": 1,
          "title": "Anomaly Id",
          "type": "string"
        },
        "anomaly_type": {
          "minLength": 1,
          "title": "Anomaly Type",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/AnomalySeverity"
        },
        "time_range": {
          "$ref": "#/$defs/TimeRange"
        },
        "rule_id": {
          "minLength": 1,
          "title": "Rule Id",
          "type": "string"
        },
        "evidence_ids": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "title": "Evidence Ids",
          "type": "array"
        }
      },
      "required": [
        "anomaly_id",
        "anomaly_type",
        "severity",
        "time_range",
        "rule_id",
        "evidence_ids"
      ],
      "title": "Anomaly",
      "type": "object"
    },
    "AnomalySeverity": {
      "description": "确定性异常的严重程度枚举。",
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ],
      "title": "AnomalySeverity",
      "type": "string"
    },
    "ConfirmationMethod": {
      "description": "工程师确认故障时采用的方法。",
      "enum": [
        "INSPECTION",
        "REPAIR_RESULT",
        "MANUFACTURER_DIAGNOSTIC"
      ],
      "title": "ConfirmationMethod",
      "type": "string"
    },
    "ConfirmedFault": {
      "additionalProperties": false,
      "description": "表示由已认证人员通过明确方法确认的故障事实。",
      "properties": {
        "confirmed_fault_id": {
          "minLength": 1,
          "title": "Confirmed Fault Id",
          "type": "string"
        },
        "fault_code": {
          "minLength": 1,
          "title": "Fault Code",
          "type": "string"
        },
        "confirmed_by": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Confirmed By",
          "type": "string"
        },
        "confirmed_at": {
          "format": "date-time",
          "title": "Confirmed At",
          "type": "string"
        },
        "confirmation_method": {
          "$ref": "#/$defs/ConfirmationMethod"
        },
        "source_hypothesis_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Hypothesis Id"
        }
      },
      "required": [
        "confirmed_fault_id",
        "fault_code",
        "confirmed_by",
        "confirmed_at",
        "confirmation_method"
      ],
      "title": "ConfirmedFault",
      "type": "object"
    },
    "DataQualityStatus": {
      "description": "查询数据整体质量状态。",
      "enum": [
        "ACCEPTABLE",
        "DEGRADED",
        "INSUFFICIENT"
      ],
      "title": "DataQualityStatus",
      "type": "string"
    },
    "DataQualitySummary": {
      "additionalProperties": false,
      "description": "汇总完整率、时间解析、重复与间隔质量，并声明允许的分析。",
      "properties": {
        "status": {
          "$ref": "#/$defs/DataQualityStatus"
        },
        "expected_points": {
          "minimum": 0,
          "title": "Expected Points",
          "type": "integer"
        },
        "observed_points": {
          "minimum": 0,
          "title": "Observed Points",
          "type": "integer"
        },
        "valid_timestamp_points": {
          "minimum": 0,
          "title": "Valid Timestamp Points",
          "type": "integer"
        },
        "completeness": {
          "maximum": 1,
          "minimum": 0,
          "title": "Completeness",
          "type": "number"
        },
        "timestamp_parse_failure_count": {
          "minimum": 0,
          "title": "Timestamp Parse Failure Count",
          "type": "integer"
        },
        "duplicate_count": {
          "minimum": 0,
          "title": "Duplicate Count",
          "type": "integer"
        },
        "gap_count": {
          "minimum": 0,
          "title": "Gap Count",
          "type": "integer"
        },
        "maximum_gap_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Gap Seconds"
        },
        "allowed_analyses": {
          "items": {
            "$ref": "#/$defs/AllowedAnalysis"
          },
          "title": "Allowed Analyses",
          "type": "array"
        },
        "warnings": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "status",
        "expected_points",
        "observed_points",
        "valid_timestamp_points",
        "completeness",
        "timestamp_parse_failure_count",
        "duplicate_count",
        "gap_count",
        "allowed_analyses"
      ],
      "title": "DataQualitySummary",
      "type": "object"
    },
    "DiagnosisStatus": {
      "description": "一次诊断运行的业务结果状态。",
      "enum": [
        "NO_DATA",
        "INSUFFICIENT_DATA",
        "NO_DEVICE_EVENT_OR_ENABLED_ANOMALY",
        "DEVICE_ALARM_REPORTED",
        "DEVICE_FAULT_REPORTED",
        "ANOMALY_DETECTED",
        "HYPOTHESES_AVAILABLE",
        "PARTIALLY_COMPLETED",
        "FAILED"
      ],
      "title": "DiagnosisStatus",
      "type": "string"
    },
    "DiagnosisVersions": {
      "additionalProperties": false,
      "description": "记录诊断运行使用的规则、知识和模型版本。",
      "properties": {
        "rule_version": {
          "minLength": 1,
          "title": "Rule Version",
          "type": "string"
        },
        "knowledge_version": {
          "minLength": 1,
          "title": "Knowledge Version",
          "type": "string"
        },
        "model_version": {
          "minLength": 1,
          "title": "Model Version",
          "type": "string"
        }
      },
      "required": [
        "rule_version",
        "knowledge_version",
        "model_version"
      ],
      "title": "DiagnosisVersions",
      "type": "object"
    },
    "EventSource": {
      "description": "上报事件的数据来源类别。",
      "enum": [
        "DEVICE_REPORTED"
      ],
      "title": "EventSource",
      "type": "string"
    },
    "EventType": {
      "description": "设备上报事件类别。",
      "enum": [
        "FAULT",
        "ALARM",
        "STATUS_CHANGE"
      ],
      "title": "EventType",
      "type": "string"
    },
    "EvidenceStatus": {
      "description": "声明当前证据是否充分的状态。",
      "enum": [
        "SUFFICIENT",
        "INSUFFICIENT"
      ],
      "title": "EvidenceStatus",
      "type": "string"
    },
    "Hypothesis": {
      "additionalProperties": false,
      "description": "表达尚未确认的故障解释及其支持、反驳证据和待验证条件。",
      "properties": {
        "hypothesis_id": {
          "minLength": 1,
          "title": "Hypothesis Id",
          "type": "string"
        },
        "hypothesis_code": {
          "minLength": 1,
          "title": "Hypothesis Code",
          "type": "string"
        },
        "target_component": {
          "$ref": "#/$defs/HypothesisTarget"
        },
        "score": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Score"
        },
        "supporting_evidence_ids": {
          "default": [],
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "type": "string"
          },
          "title": "Supporting Evidence Ids",
          "type": "array"
        },
        "contradicting_evidence_ids": {
          "default": [],
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "type": "string"
          },
          "title": "Contradicting Evidence Ids",
          "type": "array"
        },
        "unverified_conditions": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Unverified Conditions",
          "type": "array"
        },
        "evidence_status": {
          "$ref": "#/$defs/EvidenceStatus",
          "default": "SUFFICIENT"
        }
      },
      "required": [
        "hypothesis_id",
        "hypothesis_code",
        "target_component"
      ],
      "title": "Hypothesis",
      "type": "object"
    },
    "HypothesisTarget": {
      "description": "故障假设可能指向的组件范围。",
      "enum": [
        "INVERTER",
        "MOTOR",
        "DRIVE_SYSTEM",
        "UNKNOWN"
      ],
      "title": "HypothesisTarget",
      "type": "string"
    },
    "Recommendation": {
      "additionalProperties": false,
      "description": "表示尚未执行的检查或信息收集建议，不包含设备控制动作。",
      "properties": {
        "recommendation_id": {
          "minLength": 1,
          "title": "Recommendation Id",
          "type": "string"
        },
        "recommendation_code": {
          "minLength": 1,
          "title": "Recommendation Code",
          "type": "string"
        },
        "recommendation_type": {
          "$ref": "#/$defs/RecommendationType"
        },
        "priority": {
          "$ref": "#/$defs/RecommendationPriority"
        },
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "related_hypothesis_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Related Hypothesis Ids",
          "type": "array"
        },
        "supporting_evidence_ids": {
          "default": [],
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "type": "string"
          },
          "title": "Supporting Evidence Ids",
          "type": "array"
        },
        "evidence_status": {
          "$ref": "#/$defs/EvidenceStatus",
          "default": "SUFFICIENT"
        }
      },
      "required": [
        "recommendation_id",
        "recommendation_code",
        "recommendation_type",
        "priority",
        "description"
      ],
      "title": "Recommendation",
      "type": "object"
    },
    "RecommendationPriority": {
      "description": "用于排序建议的业务优先级，不代表工业安全等级。",
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH"
      ],
      "title": "RecommendationPriority",
      "type": "string"
    },
    "RecommendationType": {
      "description": "只读诊断可给出的非控制类后续建议。",
      "enum": [
        "INSPECTION",
        "DATA_COLLECTION",
        "KNOWLEDGE_REVIEW"
      ],
      "title": "RecommendationType",
      "type": "string"
    },
    "ReportedEvent": {
      "additionalProperties": false,
      "description": "记录设备上报的故障、告警或状态变化事实，不代表根因确认。",
      "properties": {
        "event_type": {
          "$ref": "#/$defs/EventType"
        },
        "event_code": {
          "minLength": 1,
          "title": "Event Code",
          "type": "string"
        },
        "reported_at": {
          "format": "date-time",
          "title": "Reported At",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/EventSource",
          "default": "DEVICE_REPORTED"
        },
        "evidence_ids": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "title": "Evidence Ids",
          "type": "array"
        }
      },
      "required": [
        "event_type",
        "event_code",
        "reported_at",
        "evidence_ids"
      ],
      "title": "ReportedEvent",
      "type": "object"
    },
    "TimeRange": {
      "additionalProperties": false,
      "description": "表示左闭右开语义的有效时间范围，并统一归一化为 UTC。",
      "properties": {
        "start": {
          "format": "date-time",
          "title": "Start",
          "type": "string"
        },
        "end": {
          "format": "date-time",
          "title": "End",
          "type": "string"
        }
      },
      "required": [
        "start",
        "end"
      ],
      "title": "TimeRange",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "汇总数据质量、事件、异常、假设、证据及可选人工确认结果。",
  "properties": {
    "diagnosis_id": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Diagnosis Id",
      "type": "string"
    },
    "asset_id": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Asset Id",
      "type": "string"
    },
    "time_range": {
      "$ref": "#/$defs/TimeRange"
    },
    "status": {
      "$ref": "#/$defs/DiagnosisStatus"
    },
    "data_quality": {
      "$ref": "#/$defs/DataQualitySummary"
    },
    "reported_events": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ReportedEvent"
      },
      "title": "Reported Events",
      "type": "array"
    },
    "anomalies": {
      "default": [],
      "items": {
        "$ref": "#/$defs/Anomaly"
      },
      "title": "Anomalies",
      "type": "array"
    },
    "hypotheses": {
      "default": [],
      "items": {
        "$ref": "#/$defs/Hypothesis"
      },
      "title": "Hypotheses",
      "type": "array"
    },
    "recommendations": {
      "default": [],
      "items": {
        "$ref": "#/$defs/Recommendation"
      },
      "title": "Recommendations",
      "type": "array"
    },
    "confirmed_fault": {
      "anyOf": [
        {
          "$ref": "#/$defs/ConfirmedFault"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "evidence_ids": {
      "default": [],
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "type": "string"
      },
      "title": "Evidence Ids",
      "type": "array"
    },
    "versions": {
      "$ref": "#/$defs/DiagnosisVersions"
    }
  },
  "required": [
    "diagnosis_id",
    "asset_id",
    "time_range",
    "status",
    "data_quality",
    "versions"
  ],
  "title": "DiagnosisResult",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:fault-agent:contract:1.0.0:diagnosis-result",
  "x-contract-version": "1.0.0"
}
