{
  "$defs": {
    "EvidenceStatus": {
      "description": "声明当前证据是否充分的状态。",
      "enum": [
        "SUFFICIENT",
        "INSUFFICIENT"
      ],
      "title": "EvidenceStatus",
      "type": "string"
    },
    "HypothesisTarget": {
      "description": "故障假设可能指向的组件范围。",
      "enum": [
        "INVERTER",
        "MOTOR",
        "DRIVE_SYSTEM",
        "UNKNOWN"
      ],
      "title": "HypothesisTarget",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "表达尚未确认的故障解释及其支持、反驳证据和待验证条件。",
  "properties": {
    "hypothesis_id": {
      "minLength": 1,
      "title": "Hypothesis Id",
      "type": "string"
    },
    "hypothesis_code": {
      "minLength": 1,
      "title": "Hypothesis Code",
      "type": "string"
    },
    "target_component": {
      "$ref": "#/$defs/HypothesisTarget"
    },
    "score": {
      "anyOf": [
        {
          "maximum": 1,
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Score"
    },
    "supporting_evidence_ids": {
      "default": [],
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "type": "string"
      },
      "title": "Supporting Evidence Ids",
      "type": "array"
    },
    "contradicting_evidence_ids": {
      "default": [],
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "type": "string"
      },
      "title": "Contradicting Evidence Ids",
      "type": "array"
    },
    "unverified_conditions": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Unverified Conditions",
      "type": "array"
    },
    "evidence_status": {
      "$ref": "#/$defs/EvidenceStatus",
      "default": "SUFFICIENT"
    }
  },
  "required": [
    "hypothesis_id",
    "hypothesis_code",
    "target_component"
  ],
  "title": "Hypothesis",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:fault-agent:contract:1.0.0:hypothesis",
  "x-contract-version": "1.0.0"
}
