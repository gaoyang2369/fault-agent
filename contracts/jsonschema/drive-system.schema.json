{
  "$defs": {
    "AssetStatus": {
      "description": "资产启用状态枚举。",
      "enum": [
        "ACTIVE",
        "INACTIVE"
      ],
      "title": "AssetStatus",
      "type": "string"
    },
    "AssetType": {
      "description": "资产类型枚举。",
      "enum": [
        "DRIVE_SYSTEM"
      ],
      "title": "AssetType",
      "type": "string"
    },
    "Component": {
      "additionalProperties": false,
      "description": "描述属于某一资产的变频器或电机组件及其已知身份信息。",
      "properties": {
        "component_id": {
          "minLength": 1,
          "title": "Component Id",
          "type": "string"
        },
        "asset_id": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Asset Id",
          "type": "string"
        },
        "component_type": {
          "$ref": "#/$defs/ComponentType"
        },
        "manufacturer": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Manufacturer"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model"
        },
        "firmware_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Firmware Version"
        }
      },
      "required": [
        "component_id",
        "asset_id",
        "component_type"
      ],
      "title": "Component",
      "type": "object"
    },
    "ComponentType": {
      "description": "驱动系统内可独立识别的组件类型枚举。",
      "enum": [
        "INVERTER",
        "MOTOR"
      ],
      "title": "ComponentType",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "描述由独立变频器与电机组成的一套驱动系统资产。",
  "properties": {
    "asset_id": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Asset Id",
      "type": "string"
    },
    "asset_code": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Asset Code",
      "type": "string"
    },
    "display_name": {
      "minLength": 1,
      "title": "Display Name",
      "type": "string"
    },
    "asset_type": {
      "$ref": "#/$defs/AssetType",
      "default": "DRIVE_SYSTEM"
    },
    "status": {
      "$ref": "#/$defs/AssetStatus"
    },
    "components": {
      "items": {
        "$ref": "#/$defs/Component"
      },
      "minItems": 2,
      "title": "Components",
      "type": "array"
    }
  },
  "required": [
    "asset_id",
    "asset_code",
    "display_name",
    "status",
    "components"
  ],
  "title": "DriveSystem",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:fault-agent:contract:1.0.0:drive-system",
  "x-contract-version": "1.0.0"
}
