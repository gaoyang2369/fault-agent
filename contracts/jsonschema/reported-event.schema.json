{
  "$defs": {
    "EventSource": {
      "description": "上报事件的数据来源类别。",
      "enum": [
        "DEVICE_REPORTED"
      ],
      "title": "EventSource",
      "type": "string"
    },
    "EventType": {
      "description": "设备上报事件类别。",
      "enum": [
        "FAULT",
        "ALARM",
        "STATUS_CHANGE"
      ],
      "title": "EventType",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "记录设备上报的故障、告警或状态变化事实，不代表根因确认。",
  "properties": {
    "event_type": {
      "$ref": "#/$defs/EventType"
    },
    "event_code": {
      "minLength": 1,
      "title": "Event Code",
      "type": "string"
    },
    "reported_at": {
      "format": "date-time",
      "title": "Reported At",
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/EventSource",
      "default": "DEVICE_REPORTED"
    },
    "evidence_ids": {
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "title": "Evidence Ids",
      "type": "array"
    }
  },
  "required": [
    "event_type",
    "event_code",
    "reported_at",
    "evidence_ids"
  ],
  "title": "ReportedEvent",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:fault-agent:contract:1.0.0:reported-event",
  "x-contract-version": "1.0.0"
}
