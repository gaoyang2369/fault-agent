# Keep real credentials outside the repository.
REAL_DATA_DSN=mysql+pymysql://user:password@host:3306/database
REAL_DATA_TABLE=real_data
REAL_DATA_SAMPLE_LIMIT=10000
REAL_DATA_QUERY_TIMEOUT_SECONDS=15
SOURCE_TIMEZONE=Asia/Shanghai
REAL_DATA_MAX_SCAN_ROWS=100000
REAL_DATA_CREATE_TIME_FILTER_BUFFER_SECONDS=3600
TELEMETRY_MAX_RETURN_POINTS=10000
TELEMETRY_NOMINAL_INTERVAL_SECONDS=3
TELEMETRY_GAP_WARNING_SECONDS=9
TELEMETRY_ACCEPTABLE_COMPLETENESS=0.95
TELEMETRY_INSUFFICIENT_COMPLETENESS=0.80
